# Template for .env used by docker-compose.yml — copy and adjust:
#   cp .env.example .env
# Every value has the same default in docker-compose.yml, so .env is only
# needed to override.

DAGSTER_WEB_PORT=3000

# MinIO connection (from inside containers, host.docker.internal = the host)
MINIO_ENDPOINT_URL=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
BUCKET_URL=s3://evd/

# Per-source API tokens. The containers have no .dlt/secrets.toml, so these
# must be set here (dlt maps __-separated env vars onto its config paths).

# LIMS API token
LIMS_API_TOKEN=your_api_token_here

# UHAI Database credentials
UHAI_DATABASE_URL=your_api_token_here

# CBS Integration API key (Admin -> API Keys in the CBS web app).
CBS_API_KEY=cbs_your_api_key_here

# KRCS Data Capture Forms (Frappe) API
KRCS_EVD_SCREENING_BASE_URL=https://forms.krcs.example/api/method/
KRCS_EVD_SCREENING_API_KEY=your_api_token_here
KRCS_EVD_SCREENING_API_SECRET=your_api_token_here
